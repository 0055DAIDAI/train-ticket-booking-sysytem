<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mapper.StationMapper">

    <select id="findById" resultType="org.example.pojo.Station">
        SELECT
        id, station_name AS stationName,
        city
        FROM station
        WHERE id = #{id}
    </select>


</mapper>